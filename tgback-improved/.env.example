PORT=3000
DATABASE_URL=postgresql://user:password@host:5432/messenger

# JWT Secret — генерируй случайный: openssl rand -hex 32
JWT_SECRET=replace-with-a-long-random-secret-key

# SMTP (Resend.com — бесплатно 3000 писем/мес: https://resend.com)
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_USER=resend
SMTP_PASS=re_your_resend_api_key_here
FROM_EMAIL=noreply@yourdomain.com

# Groq AI (бесплатно: https://console.groq.com)
GROQ_API_KEY=gsk_your_groq_key_here

# CORS (URL-ы клиентов через запятую)
ALLOWED_ORIGINS=*
NODE_ENV=production
